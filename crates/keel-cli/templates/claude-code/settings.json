{
  "mcpServers": {
    "keel": {
      "command": "keel",
      "args": ["serve", "--mcp"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "timeout 10 keel map --llm --cached"
          }
        ]
      }
    ]
  }
}
